# ─────────────────────────────────────────────────────────────────────────────
# Lacrei Saúde API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env com valores reais
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=django-insecure-substitua-por-uma-chave-segura-em-producao
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Banco de dados
DB_NAME=lacrei_db
DB_USER=lacrei_user
DB_PASSWORD=lacrei_pass
DB_HOST=localhost
DB_PORT=5432

# CORS (origens separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Autenticação — API Keys (separe múltiplas por vírgula)
VALID_API_KEYS=dev-api-key-change-in-prod

# Monitoramento
SENTRY_DSN=

# AWS (produção)
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
